views:
  - type: table
    name: Table
    filters:
      and:
        - file.hasTag("school/schoolwork")
        - subject == link("CMSC 57")
    groupBy:
      property: type
      direction: ASC
    order:
      - finished
      - file.name
      - deadline
      - score
      - total score
      - type
      - submission
    sort:
      - property: finished
        direction: ASC
      - property: deadline
        direction: ASC
